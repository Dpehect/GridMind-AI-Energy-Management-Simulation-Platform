{
  "name": "gridmind",
  "version": "1.0.1",
  "private": true,
  "description": "Local-first energy management, simulation and operations platform.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "audit:release": "tsx scripts/release-health.ts",
    "prepare:e2e": "npm run db:generate && npm run db:push && npm run db:seed && npm run db:seed:auth",
    "check": "npm run typecheck && npm run lint && npm run test && npm run format:check",
    "verify": "npm run check && npm run build && npm run prepare:e2e && npm run test:e2e && npm run audit:release",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:auth": "tsx prisma/seed-auth.ts",
    "db:studio": "prisma studio",
    "db:backup": "tsx scripts/backup-database.ts",
    "db:restore": "tsx scripts/restore-database.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@prisma/client": "6.16.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-tooltip": "1.2.8",
    "@react-three/drei": "10.7.6",
    "@react-three/fiber": "9.4.0",
    "@react-three/postprocessing": "3.0.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "embla-carousel-react": "8.6.0",
    "framer-motion": "12.23.24",
    "gsap": "3.13.0",
    "lenis": "1.3.11",
    "lucide-react": "0.468.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "postprocessing": "6.37.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "7.66.0",
    "sonner": "2.0.7",
    "split-type": "0.3.4",
    "tailwind-merge": "3.3.1",
    "three": "0.180.0",
    "vaul": "1.1.2",
    "zod": "3.25.76",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@eslint/eslintrc": "3.3.1",
    "@playwright/test": "1.55.0",
    "@tailwindcss/postcss": "4.1.14",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.18.6",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@types/three": "0.180.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.36.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "27.0.0",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "prisma": "6.16.3",
    "tailwindcss": "4.1.14",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
