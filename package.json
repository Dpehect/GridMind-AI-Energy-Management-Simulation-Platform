    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:auth": "tsx prisma/seed-auth.ts",
    "db:seed:tenancy": "tsx prisma/seed-tenancy.ts",
    "db:seed:workflows": "tsx prisma/seed-workflows.ts",
    "db:studio": "prisma studio",
    "db:backup": "tsx scripts/backup-database.ts",
    "db:backup:v2": "tsx scripts/backup-database-v2.ts",
    "db:verify-backups": "tsx scripts/verify-backups.ts",
    "db:restore": "tsx scripts/restore-database.ts",
    "db:test-restore": "tsx scripts/restore-smoke-test.ts",
    "prepare:e2e": "npm run db:generate && npm run db:push && npm run db:seed && npm run db:seed:auth && npm run db:seed:tenancy && npm run db:seed:workflows",
    "preflight:production": "tsx scripts/preflight-production.ts",
    "release:check-upgrade": "tsx scripts/upgrade-check.ts",
    "release:seed": "tsx scripts/final-seed-sequence.ts",
    "release:validate": "tsx scripts/final-release-validator.ts",
    "release:verify-all": "tsx scripts/final-verify-sequence.ts",
    "check:runtime": "npm run env:validate && npm run audit:schema && npm run check:routes && npm run check:imports",
    "check": "npm run check:runtime && npm run typecheck && npm run lint && npm run test && npm run format:check",
    "verify": "npm run check && npm run build && npm run prepare:e2e && npm run test:e2e && npm run audit:release",
    "verify:enterprise": "npm run check:runtime && npm run typecheck && npm run lint && npm run test && npm run test:integration && npm run test:security && npm run build && npm run audit:security && npm run audit:compliance",
    "ux:audit": "vitest run tests/breadcrumbs.spec.ts tests/role-dashboard.spec.ts tests/empty-state.spec.tsx",
    "postinstall": "prisma generate"
  },
