    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.18.6",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@types/three": "0.180.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.36.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "27.0.0",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "prisma": "6.16.3",
    "tailwindcss": "4.1.14",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
