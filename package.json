    "test:security": "vitest run tests/security",
    "test:enterprise:e2e": "playwright test tests/e2e",
    "audit:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "audit:release": "tsx scripts/release-health.ts",
    "audit:schema": "tsx scripts/phase39-schema-audit.ts",
    "audit:security": "tsx scripts/security-audit.ts",
