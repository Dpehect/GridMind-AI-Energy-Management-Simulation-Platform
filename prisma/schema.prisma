generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EnergySource {
  GRID
  SOLAR
  WIND
  GENERATOR
  BATTERY
  OTHER
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

enum AlertSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  SNOOZED
}

enum ScenarioStatus {
  DRAFT
  READY
  RUNNING
  COMPLETED
  FAILED
}

enum RecommendationStatus {
  NEW
  ACCEPTED
  DISMISSED
  COMPLETED
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  timezone    String   @default("Europe/Istanbul")
  currency    String   @default("TRY")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buildings      Building[]
  tariffs        Tariff[]
  goals          EnergyGoal[]
  scenarios      Scenario[]
  recommendations Recommendation[]
  reports        Report[]
  activityLogs   ActivityLog[]
  settings       WorkspaceSetting[]
}

model Building {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  code        String
  address     String?
  type        String
  floorAreaM2 Float
  occupancy   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  floors    Floor[]
  meters    Meter[]
  devices   Device[]
  alerts    Alert[]
  maintenanceRecords MaintenanceRecord[]

  @@unique([workspaceId, code])
  @@index([workspaceId, isActive])
}

model Floor {
  id         String   @id @default(cuid())
  buildingId String
  name       String
  level      Int
  areaM2     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  zones    Zone[]

  @@unique([buildingId, level])
}

model Zone {
  id        String   @id @default(cuid())
  floorId   String
  name      String
  code      String
  category  String
  areaM2    Float
  targetKwh Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floor   Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  meters  Meter[]
  devices Device[]
  alerts  Alert[]

  @@unique([floorId, code])
  @@index([floorId])
}

model Meter {
  id          String       @id @default(cuid())
  buildingId  String
  zoneId      String?
  name        String
  serialNumber String      @unique
  source      EnergySource @default(GRID)
  unit        String       @default("kWh")
  multiplier  Float        @default(1)
  installedAt DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  zone     Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  readings Reading[]
  alerts   Alert[]

  @@index([buildingId, isActive])
  @@index([zoneId])
}

model Device {
  id              String       @id @default(cuid())
  buildingId      String
  zoneId          String?
  name            String
  assetTag        String       @unique
  category        String
  ratedPowerKw    Float
  status          DeviceStatus @default(ACTIVE)
  operatingHours  Float        @default(0)
  installedAt     DateTime?
  expectedLifeYears Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  zone     Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  alerts   Alert[]
  maintenanceRecords MaintenanceRecord[]

  @@index([buildingId, status])
  @@index([zoneId])
}

model Reading {
  id         String   @id @default(cuid())
  meterId    String
  capturedAt DateTime
  value      Float
  quality    Float    @default(1)
  source     String   @default("manual")
  metadata   Json?
  createdAt  DateTime @default(now())

  meter Meter @relation(fields: [meterId], references: [id], onDelete: Cascade)

  @@unique([meterId, capturedAt])
  @@index([capturedAt])
  @@index([meterId, capturedAt])
}

model Tariff {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  currency    String   @default("TRY")
  pricePerKwh Float
  peakPrice   Float?
  offPeakPrice Float?
  validFrom   DateTime
  validUntil  DateTime?
  rules       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@index([workspaceId, validFrom])
}

model Alert {
  id          String        @id @default(cuid())
  buildingId  String
  zoneId      String?
  meterId     String?
  deviceId    String?
  title       String
  description String
  severity    AlertSeverity
  status      AlertStatus   @default(OPEN)
  detectedAt  DateTime      @default(now())
  resolvedAt  DateTime?
  confidence  Float?
  evidence    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  zone     Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  meter    Meter?   @relation(fields: [meterId], references: [id], onDelete: SetNull)
  device   Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([buildingId, status, severity])
  @@index([detectedAt])
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  buildingId  String
  deviceId    String?
  title       String
  description String?
  scheduledAt DateTime
  completedAt DateTime?
  cost        Float?
  technician  String?
  outcome     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  device   Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  @@index([buildingId, scheduledAt])
}

model EnergyGoal {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  metric      String
  baseline    Float
  target      Float
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@index([workspaceId, endsAt])
}

model Scenario {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      ScenarioStatus @default(DRAFT)
  assumptions Json
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs      SimulationRun[]
  @@index([workspaceId, status])
}

model SimulationRun {
  id             String   @id @default(cuid())
  scenarioId     String
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  baselineKwh    Float?
  projectedKwh   Float?
  baselineCost   Float?
  projectedCost  Float?
  carbonSavedKg  Float?
  confidence     Float?
  result         Json?
  errorMessage   String?

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  @@index([scenarioId, startedAt])
}

model Recommendation {
  id          String               @id @default(cuid())
  workspaceId String
  title       String
  summary     String
  category    String
  impactScore Float
  effortScore Float
  confidence  Float
  estimatedSavingsKwh Float?
  estimatedSavingsCost Float?
  status      RecommendationStatus @default(NEW)
  evidence    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@index([workspaceId, status, impactScore])
}

model Report {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  type        String
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("draft")
  content     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@index([workspaceId, createdAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  actor       String   @default("local-system")
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@index([workspaceId, createdAt])
}

model WorkspaceSetting {
  id          String   @id @default(cuid())
  workspaceId String
  key         String
  value       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@unique([workspaceId, key])
}
