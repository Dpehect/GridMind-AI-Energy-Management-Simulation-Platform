// Merge into prisma/schema.prisma.

model BackgroundJob {
  id             String   @id @default(cuid())
  workspaceId    String?
  type           String
  payload        Json
  status         String   @default("queued")
  priority       Int      @default(100)
  attempts       Int      @default(0)
  maxAttempts    Int      @default(5)
  runAt          DateTime @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  lastError      String?
  result         Json?
  idempotencyKey String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([idempotencyKey])
  @@index([status, runAt, priority])
  @@index([workspaceId, type, createdAt])
}

model JobAttempt {
  id            String   @id @default(cuid())
  backgroundJobId String
  attempt       Int
  workerId      String
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  status        String
  error         String?
  durationMs    Int?

  backgroundJob BackgroundJob @relation(fields: [backgroundJobId], references: [id], onDelete: Cascade)

  @@index([backgroundJobId, attempt])
}

model AutomationRule {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  triggerType String
  trigger     Json
  actionType  String
  action      Json
  enabled     Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, enabled, nextRunAt])
}
